---
const issues = [
  'Auth that only works on Tuesdays',
  'The entire app is one 4,000-line file',
  'Login page that logs you out',
  '47 unused npm packages',
  'CSS that works by accident',
  'API keys committed to GitHub',
  'Database schema that makes senior devs cry',
  'Catch blocks that catch nothing',
  '500 errors nobody can explain',
  '"It works on my machine"',
  'Payment flow with no error handling',
  'Tests that test nothing',
  'node_modules pushed to production',
  'Secret key is literally "secret"',
  'Every component re-renders everything',
  'One function with 23 parameters',
  'No types anywhere, ever',
  'Deploy pipeline held together with hope',
];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    <ul class="marquee-list">
      {issues.map(item => <li class="marquee-item">{item}</li>)}
    </ul>
    <ul class="marquee-list">
      {issues.map(item => <li class="marquee-item">{item}</li>)}
    </ul>
  </div>
</div>

<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee {
    overflow: hidden;
    padding: 2.25rem 0;
    position: relative;
    background: var(--surface);
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .marquee::before,
  .marquee::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    z-index: 1;
  }

  .marquee::before {
    top: 0;
    background: linear-gradient(90deg, transparent, var(--border-strong) 30%, var(--border-strong) 70%, transparent);
  }

  .marquee::after {
    bottom: 0;
    background: linear-gradient(90deg, transparent, var(--border-strong) 30%, var(--border-strong) 70%, transparent);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 60s linear infinite;
    will-change: transform;
  }

  .marquee-list {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    padding: 0 1.25rem;
    margin: 0;
    flex-shrink: 0;
  }

  .marquee-item {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    letter-spacing: -0.01em;
    position: relative;
    transition: color 0.3s;
  }

  .marquee-item::before {
    content: '//';
    font-family: 'DM Mono', monospace;
    color: var(--accent);
    margin-right: 0.6rem;
    font-size: 0.85rem;
    opacity: 0.4;
  }

</style>
