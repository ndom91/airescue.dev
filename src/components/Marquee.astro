---
const issues = [
  'Auth that only works on Tuesdays',
  'The entire app is one 4,000-line file',
  'Login page that logs you out',
  '47 unused npm packages',
  'CSS that works by accident',
  'API keys committed to GitHub',
  'Database schema that makes senior devs cry',
  'Catch blocks that catch nothing',
  '500 errors nobody can explain',
  '"It works on my machine"',
  'Payment flow with no error handling',
  'Tests that test nothing',
  'node_modules pushed to production',
  'Secret key is literally "secret"',
  'Every component re-renders everything',
  'One function with 23 parameters',
  'No types anywhere, ever',
  'Deploy pipeline held together with hope',
];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee-label mono">Incident Feed</div>
  <div class="marquee-track">
    <ul class="marquee-list">
      {issues.map(item => <li class="marquee-item">{item}</li>)}
    </ul>
    <ul class="marquee-list">
      {issues.map(item => <li class="marquee-item">{item}</li>)}
    </ul>
  </div>
</div>

<style>
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee {
    overflow: hidden;
    padding: 0.85rem 0;
    position: relative;
    background: var(--text);
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--text);
  }

  .marquee-label {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    padding: 0 1rem;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text);
    background: var(--accent);
    border-right: 1px solid var(--text);
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll 60s linear infinite;
    will-change: transform;
  }

  .marquee-list {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    padding: 0 1.25rem 0 9.8rem;
    margin: 0;
    flex-shrink: 0;
  }

  .marquee-item {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--on-dark-muted);
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .marquee-item::before {
    content: '//';
    font-family: var(--font-mono);
    color: var(--accent);
    margin-right: 0.6rem;
    font-size: 0.78rem;
    opacity: 0.8;
  }

  @media (max-width: 720px) {
    .marquee-label {
      position: static;
      border-right: 0;
      border-bottom: 1px solid var(--text);
      justify-content: center;
      padding: 0.42rem;
    }

    .marquee {
      padding-top: 0;
    }

    .marquee-list {
      padding-left: 1.1rem;
    }
  }

</style>
